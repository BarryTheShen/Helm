{
  "name": "@keel/renderer",
  "version": "0.1.0",
  "description": "SDUI V2 renderer, component registry, and theme system for Keel AI-UI framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest"
  },
  "dependencies": {
    "@keel/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-paper": ">=5.0.0",
    "react-native-vector-icons": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-paper": {
      "optional": true
    },
    "react-native-vector-icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-paper": "^5.15.0",
    "typescript": "~5.9.2"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BarryTheShen/Helm.git",
    "directory": "packages/renderer"
  }
}
