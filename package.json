{
  "name": "keel",
  "version": "0.1.0",
  "private": true,
  "description": "Keel — Open-source AI-UI framework for building AI-powered mobile apps with dynamic Server-Driven UI",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "jest --config packages/protocol/jest.config.js && jest --config packages/renderer/jest.config.js && jest --config examples/keel-demo/jest.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BarryTheShen/Helm.git"
  },
  "keywords": [
    "sdui",
    "server-driven-ui",
    "ai",
    "react-native",
    "mcp",
    "framework"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BarryTheShen/Helm/issues"
  },
  "homepage": "https://github.com/BarryTheShen/Helm#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.4.9"
  },
  "dependencies": {
    "puppeteer-core": "^24.40.0"
  }
}
