# Helm Backend — Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=sqlite+aiosqlite:///./helm.db

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-secure-random-key
ENCRYPTION_KEY=change-me-32-byte-fernet-key-here

# Token expiry
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# Server
SERVER_NAME=Helm
SERVER_VERSION=0.1.0
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# AI Agent (optional — add your provider key)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# MCP Server
MCP_PATH=/mcp
